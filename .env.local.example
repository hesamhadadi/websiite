# MongoDB Connection
MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/portfolio?retryWrites=true&w=majority

# Email (for contact form - use Gmail App Password)
EMAIL_USER=your@gmail.com
EMAIL_PASS=your_app_password_here
EMAIL_TO=your@gmail.com

# Site URL (for SEO & OG tags)
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_random_secret_here_min_32_chars

# GitHub OAuth App
GITHUB_ID=your_github_client_id
GITHUB_SECRET=your_github_client_secret
GITHUB_ALLOWED_USERNAME=your_github_username
