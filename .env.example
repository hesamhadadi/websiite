# ─────────────────────────────────────────────
#  Cloudinary – Image Upload
# ─────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name

# Option A – Unsigned upload (easier, recommended for personal projects)
# Create an unsigned preset in Cloudinary dashboard → Settings → Upload → Add upload preset
CLOUDINARY_UPLOAD_PRESET=your_unsigned_preset_name

# Option B – Signed upload (more secure, for production)
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret

# ─────────────────────────────────────────────
#  Database
# ─────────────────────────────────────────────
MONGODB_URI=mongodb+srv://...

# ─────────────────────────────────────────────
#  Auth (NextAuth)
# ─────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_password
